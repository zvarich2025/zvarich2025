    static void Task8()
    {
        double a = -2, b = 2, eps = 0.0001;
        Func<double, double> f = x => 3 * x + Math.Cos(x) + 1;

        if (f(a) * f(b) > 0) { Console.WriteLine("Коренів на відрізку немає."); return; }

        double x = 0;
        while ((b - a) / 2 > eps)
        {
            x = (a + b) / 2;
            if (f(x) == 0) break;
            if (f(a) * f(x) < 0) b = x; else a = x;
        }
        Console.WriteLine($"Корінь: {x:F4}. Перевірка: f(x) = {f(x):F5}");
    }

