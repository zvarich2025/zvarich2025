    #region Допоміжні методи
    static int[] GenerateArray(int count, int min, int max)
    {
        Random rnd = new Random();
        int[] arr = new int[count];
        for (int i = 0; i < count; i++) arr[i] = rnd.Next(min, max);
        return arr;
    }

    static void PrintArray(int[] arr, string message)
    {
        Console.WriteLine($"{message}: [{string.Join(", ", arr)}]");
    }

    static bool IsFibonacci(int n)
    {
        if (n < 0) return false;
        double res1 = 5 * Math.Pow(n, 2) + 4;
        double res2 = 5 * Math.Pow(n, 2) - 4;
        return IsPerfectSquare(res1) || IsPerfectSquare(res2);
    }

    static bool IsPerfectSquare(double x)
    {
        int s = (int)Math.Sqrt(x);
        return s * s == x;
    }

    static bool IsMersenne(int n)
    {
        if (n <= 0) return false;
        return (n & (n + 1)) == 0; // Число виду 2^k - 1
    }

    static bool IsFermat(int n)
    {
        // Ферма: 2^(2^k) + 1. Перші: 3, 5, 17, 257, 65537
        for (int k = 0; k < 6; k++)
        {
            double val = Math.Pow(2, Math.Pow(2, k)) + 1;
            if (n == (int)val) return true;
        }
        return false;
    }
    #endregion

    static void Task1()
    {
        Console.Write("Кількість елементів: ");
        int n = Convert.ToInt32(Console.ReadLine());
        int[] arr = GenerateArray(n, 0, 100);
        PrintArray(arr, "До сортування");

        // Selection Sort
        for (int i = 0; i < arr.Length - 1; i++)
        {
            int minIdx = i;
            for (int j = i + 1; j < arr.Length; j++)
                if (arr[j] < arr[minIdx]) minIdx = j;
            int temp = arr[minIdx];
            arr[minIdx] = arr[i];
            arr[i] = temp;
        }
        PrintArray(arr, "Після сортування");
    }

    static void Task2()
    {
        Console.Write("Межа для решета Ератосфена: ");
        int limit = Convert.ToInt32(Console.ReadLine());

        bool[] isPrime = Enumerable.Repeat(true, limit + 1).ToArray();
        isPrime[0] = isPrime[1] = false;
        for (int p = 2; p * p <= limit; p++)
            if (isPrime[p])
                for (int i = p * p; i <= limit; i += p) isPrime[i] = false;

        List<int> primes = new List<int>();
        for (int i = 2; i <= limit; i++) if (isPrime[i]) primes.Add(i);

        int[] baseArr = { 1, 10, 20 }; // Приклад "раніше відсортованого"
        int[] result = baseArr.Concat(primes).ToArray();
        PrintArray(result, "Об'єднаний масив");
    }

    static void Task3()
    {
        int[] arr = GenerateArray(20, 0, 1000);
        PrintArray(arr, "Масив");
        bool found = false;
        for (int i = 0; i < arr.Length; i++)
        {
            if (IsFibonacci(arr[i]) || IsMersenne(arr[i]) || IsFermat(arr[i]))
            {
                Console.WriteLine($"Індекс {i}: {arr[i]} (Спец. число)");
                found = true;
            }
        }
        if (!found) Console.WriteLine("Спеціальних чисел не знайдено.");
    }

    static void Task4()
    {
        int[] arr = GenerateArray(15, 0, 100);
        PrintArray(arr, "Початковий масив");

        var fib = arr.Where(IsFibonacci).ToList();
        var mer = arr.Where(IsMersenne).ToList();
        var fer = arr.Where(IsFermat).ToList();
        var rest = arr.Where(x => !IsFibonacci(x) && !IsMersenne(x) && !IsFermat(x)).ToList();

        int[] result = fib.Concat(mer).Concat(fer).Concat(rest).ToArray();
        PrintArray(result, "Результат перестановки");

        if (fib.Count + mer.Count + fer.Count == 0)
        {
            double avg = arr.Average();
            double geomAvg = Math.Pow(arr.Aggregate(1.0, (a, b) => a * b), 1.0 / arr.Length);
            Console.WriteLine($"Середнє: {avg}, Геом. середнє: {geomAvg}");
        }
    }

    static void Task5()
    {
        int[] arr = GenerateArray(10, 0, 50);
        Array.Sort(arr);
        PrintArray(arr, "Відсортований масив");
        Console.Write("Шуканий елемент: ");
        int key = Convert.ToInt32(Console.ReadLine());

        // Ручний бінарний пошук
        int low = 0, high = arr.Length - 1, manualIdx = -1;
        while (low <= high)
        {
            int mid = (low + high) / 2;
            if (arr[mid] == key) { manualIdx = mid; break; }
            if (arr[mid] < key) low = mid + 1; else high = mid - 1;
        }

        // Array.BinarySearch
        int autoIdx = Array.BinarySearch(arr, key);

        Console.WriteLine($"Ручний пошук: {manualIdx}, Array.BinarySearch: {autoIdx}");
    }

